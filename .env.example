# CourtCheck backend env vars
# Copy this file to .env and fill in the real values, OR set as Modal secrets
# (see SETUP.md for the `modal secret create` commands).

# Modal webhook auth — protects the /process_video endpoint from public calls.
# Generate via: python -c "import secrets; print(secrets.token_urlsafe(32))"
MODAL_WEBHOOK_SECRET=

# Supabase service role — used by the Modal worker to write match results.
# Find at: supabase.com/dashboard → Project Settings → API.
SUPABASE_URL=https://<your-project>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# OpenAI — used for scouting-report LLM summarization.
OPENAI_API_KEY=
