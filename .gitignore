# Media and local data
data/
input_videos/
backend/output_videos/
backend/runs/
backend/tracker_stubs/
backend/analysis/
# Keep backend/training/*.py source tracked so teammates can reproduce the training pipeline.
# Only ignore the heavy/regenerable artifacts: clip datasets, eval reports, caches.
backend/training/data/
backend/training/runs/
backend/training/__pycache__/
backend/calibration_frames/videos/
*.mp4
*.mov

# Node / frontend artifacts
**/node_modules/
frontend/web/.next/
frontend/web/out/
frontend/web/build/
frontend/web/dist/
frontend/web/.vercel/
*.tsbuildinfo
frontend/web/next-env.d.ts

# JS package manager logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-debug.log*

# Source-of-truth lockfile is package-lock.json (npm) per CI workflow.
# pnpm-lock.yaml is a local-only artifact for developers using pnpm.
frontend/web/pnpm-lock.yaml

# OS junk
.DS_Store
Thumbs.db

# Local-only docs — handoffs, PRDs, upgrade plans, internal session notes.
# Kept on disk for reference but not pushed to GitHub.
HANDOFF*.md
PRD*.md
upgrade-plan*.md
docs/HANDOFF*.md
docs/PRD*.md
docs/upgrade-plan*.md
docs/superpowers/

# Audit (responsive screenshots, session state) — local-only
frontend/web/scripts/audit/storageState.json
frontend/web/scripts/audit/screenshots/
frontend/web/scripts/audit/sign-in-failed.png
